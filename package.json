{
  "name": "payload-plugin-scheduler",
  "version": "1.0.0",
  "homepage:": "https://github.comw/wkentdag/payload-plugin-scheduler",
  "repository": "git@github.com:wkentdag/payload-plugin-scheduler.git",
  "description": "Scheduled posts plugin for PayloadCMS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./rsc": {
      "import": "./dist/rsc.js",
      "types": "./dist/rsc.d.ts",
      "default": "./dist/rsc.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.3.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "keywords": [
    "payload",
    "cms",
    "plugin",
    "schedule",
    "scheduler",
    "cron",
    "node-schedule"
  ],
  "scripts": {
    "build": "pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf dist",
    "dev": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.postgres.config.ts next dev dev --turbo",
    "dev:mongo": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.mongo.config.ts next dev dev --turbo",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.postgres.config.ts payload",
    "dev:payload:mongo": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.mongo.config.ts payload",
    "format": "prettier --write .",
    "generate": "pnpm generate:importMap && pnpm generate:types",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.postgres.config.ts payload generate:types",
    "generate:importMap": "cross-env PAYLOAD_CONFIG_PATH=./dev/src/payload.postgres.config.ts payload generate:importMap",
    "lint": "eslint",
    "lint:fix": "eslint ./src --fix",
    "prebuild": "pnpm generate",
    "predev": "pnpm generate",
    "prerelease": "pnpm clean && pnpm build && pnpm test",
    "release": "release-it",
    "test": "cross-env NODE_ENV=test PAYLOAD_CONFIG_PATH=./dev/src/payload.postgres.config.ts vitest run --config ./vitest.config.js",
    "test:mongo": "cross-env NODE_ENV=test PAYLOAD_CONFIG_PATH=./dev/src/payload.mongo.config.ts vitest run --config ./vitest.config.js",
    "test:postgres": "cross-env NODE_ENV=test PAYLOAD_CONFIG_PATH=./dev/src/payload.postgres.config.ts vitest run --config ./vitest.config.js"
  },
  "author": "Will Kent-Daggett",
  "license": "MIT",
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@payloadcms/db-mongodb": "3.85.0",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@swc/cli": "0.6.0",
    "@types/debug": "4.1.12",
    "@types/node": "22.19.9",
    "@types/qs": "6.9.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "7.0.3",
    "eslint": "9.23.0",
    "eslint-config-next": "16.2.6",
    "lint-staged": "17.0.5",
    "mongodb-memory-server": "10.1.4",
    "next": "16.2.6",
    "payload": "3.85.0",
    "prettier": "3.4.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "release-it": "20.0.1",
    "rimraf": "3.0.2",
    "sharp": "0.34.2",
    "simple-git-hooks": "2.13.1",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "date-fns": "3.6.0",
    "debug": "4.3.4"
  }
}
