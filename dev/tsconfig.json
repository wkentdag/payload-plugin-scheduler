{
  "extends": "../tsconfig.json",
  "exclude": ["test/**/*.ts"],
  "include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.mjs",
    "**/*.cjs",
    "**/*.ts",
    "**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "next.config.mjs",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "emitDeclarationOnly": false,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "rootDir": "..",
    "paths": {
      "@payload-config": [
        "./src/payload.postgres.config.ts"
      ],
      "payload-plugin-scheduler": [
        "../src/index.ts"
      ],
      "payload-plugin-scheduler/client": [
        "../src/client.ts"
      ],
      "payload-plugin-scheduler/rsc": [
        "../src/rsc.ts"
      ],
      "payload/generated-types": [
        "./payload-types.ts"
      ]
    }
  }
}
